{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:vercel": "npx prisma generate --schema=../backend/schema.prisma --generator client_js && npx prisma db push --schema=../backend/schema.prisma && npx prisma db seed && vite build"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^26.0.1",
		"autoprefixer": "^10.4.20",
		"prisma": "^5.22.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^3.4.9",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.80",
		"@ai-sdk/openai": "^3.0.67",
		"@ai-sdk/svelte": "^4.0.193",
		"@prisma/client": "^5.22.0",
		"@upstash/vector": "^1.2.3",
		"ai": "^6.0.193",
		"svelte-clerk": "^1.1.9",
		"zod": "^4.4.3"
	},
	"prisma": {
		"seed": "ts-node prisma/seed.ts",
		"schema": "../backend/schema.prisma"
	}
}
