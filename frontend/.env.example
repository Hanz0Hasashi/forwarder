# Clerk Authentication Keys
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Groq API Key (Powers the AI Intake & Broker Agents)
# Generate a key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Vercel Postgres (NeonDB) Variables
# These are automatically injected by Vercel when you create a database via the Storage tab.
# No need to set these manually on Vercel, just ensure they are here for local dev!
POSTGRES_PRISMA_URL="postgresql://user:password@ep-cool-snowflake.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@ep-cool-snowflake.eu-central-1.aws.neon.tech/neondb?sslmode=require"