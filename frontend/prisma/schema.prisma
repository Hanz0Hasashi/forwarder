datasource db {
  provider   = "postgresql"
  url        = env("POSTGRES_PRISMA_URL") // Pooled connection for serverless functions
  directUrl  = env("POSTGRES_URL_NON_POOLING") // Direct connection for migrations (npx prisma db push)
  extensions = [vector] // Added for pgvector support
}

generator client_js {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// Strict Roles for Login Routing
enum Role {
  CUSTOMER
  FORWARDER
  ADMIN
}

// The User Table
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      Role     @default(CUSTOMER)
  
  createdAt DateTime @default(now())

  // Relations: A user can be a customer who creates jobs, or a forwarder who drives them
  jobsCreated  Job[] @relation("CustomerJobs")
  jobsAccepted Job[] @relation("ForwarderJobs")
  
  // A forwarder can make many bids
  bids         Bid[] @relation("ForwarderBids")
}

model Job {
  id             String   @id @default(uuid())
  
  // Auto-incrementing integer for human-readable IDs (e.g. 1, 2, 3...)
  jobNumber      Int      @unique @default(autoincrement()) 
  
  // Foreign Keys: Linking the Job to actual Users
  customerId     String?  
  customer       User?    @relation("CustomerJobs", fields: [customerId], references: [id])
  
  forwarderId    String?  
  forwarder      User?    @relation("ForwarderJobs", fields: [forwarderId], references: [id])

  // Vehicle Details
  make           String
  model          String
  year           Int
  runs           String
  notes          String?

  // Route Details
  pickup         String
  delivery       String
  distance       String

  // AI Evaluation Results
  aiIsValid      Boolean
  aiReasoning    String
  aiComplexity   String

  // Budget for AI Negotiation
  targetPrice    Float?   

  // NATIVE NEON PGVECTOR
  embedding      Unsupported("vector(768)")?

  // System State
  status         String   @default("Reviewing") 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  bids           Bid[]    
}

// The Negotiation Table (Bids)
model Bid {
  id              String   @id @default(cuid())
  
  // Link to the Job
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Link to the Forwarder (Driver) making the bid
  forwarderId     String?
  forwarder       User?    @relation("ForwarderBids", fields: [forwarderId], references: [id])
  driverName      String   
  
  // The Money
  amount          Float    
  aiCounterAmount Float?   
  
  // The State of the Negotiation
  status          String   @default("PENDING_AI_REVIEW") 
  createdAt       DateTime @default(now())
}

model DriverRequest {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String
  
  // Optional Business Details
  companyName     String?
  vatNumber       String?
  
  // Equipment & Compliance
  licenseClass    String   
  trailerType     String   
  hasWinch        Boolean  @default(false) 
  hasCode95       Boolean  @default(false)
  
  status          String   @default("PENDING") 
  createdAt       DateTime @default(now())
}
