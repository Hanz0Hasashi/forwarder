# Groq API Key (Powers the Pydantic AI Dispatcher)
# Generate a key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Prisma Database Connection String
# Replace user, password, and port with your local PostgreSQL credentials
DATABASE_URL="postgresql://user:password@localhost:5432/shutup_forwarder"